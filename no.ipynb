   "source": [
    "\"\"\"wap to print fizz if no.is divisible by 3,  buzz if div by 5, fizzbuzz if div by 3 and 5\"\"\"\n",
    "\n",
    "\n",
    "n= int(input(\"Enter a number\"))\n",
    "if (n%3==0 and n%5==0):\n",
    "    print(\"fizzbuzz\")\n",
    "elif (n%3==0):\n",
    "    print(\"Fizz\")\n",
    "elif (n%5==0):\n",
    "    print(\"buzz\")\n",
    "else:\n",
    "    print(n)"
   ]
  }
