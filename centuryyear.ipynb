   "source": [
    "y = input(\"ENTER YEAR: \")\n",
    "\n",
    "if y.isdigit():\n",
    "    y = int(y)\n",
    "    if y % 100 == 0:\n",
    "        print(\"CENTURY YEAR\")\n",
    "    else:\n",
    "        print(\"NOT A CENTURY YEAR\")\n",
    "else:\n",
    "    print(\"Please enter a valid number\")"
   ]
  }
