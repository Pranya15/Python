<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>800</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Fantasy Cricket App</string>
  </property>

  <!-- CENTRAL WIDGET -->
  <widget class="QWidget" name="centralwidget">

   <!-- MAIN LAYOUT -->
   <layout class="QGridLayout" name="gridLayout">

    <!-- LEFT LABEL -->
    <item row="0" column="0">
     <widget class="QLabel" name="labelAvailable">
      <property name="text">
       <string>Available Players</string>
      </property>
     </widget>
    </item>

    <!-- RIGHT LABEL -->
    <item row="0" column="2">
     <widget class="QLabel" name="labelSelected">
      <property name="text">
       <string>Selected Players</string>
      </property>
     </widget>
    </item>

    <!-- POINTS -->
    <item row="1" column="1">
     <widget class="QLabel" name="labelPointsAvailable">
      <property name="text">
       <string>Points Available: 1000</string>
      </property>
     </widget>
    </item>

    <item row="2" column="1">
     <widget class="QLabel" name="labelPointsUsed">
      <property name="text">
       <string>Points Used: 0</string>
      </property>
     </widget>
    </item>

    <!-- LEFT LIST -->
    <item row="3" column="0">
     <widget class="QListWidget" name="listAvailable"/>
    </item>

    <!-- RIGHT LIST -->
    <item row="3" column="2">
     <widget class="QListWidget" name="listSelected"/>
    </item>

    <!-- RADIO BUTTONS -->
    <item row="3" column="1">
     <layout class="QVBoxLayout">
      <item>
       <widget class="QRadioButton" name="radioBAT">
        <property name="text">
         <string>BAT</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QRadioButton" name="radioBOWL">
        <property name="text">
         <string>BOWL</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QRadioButton" name="radioALL">
        <property name="text">
         <string>ALL</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QRadioButton" name="radioWK">
        <property name="text">
         <string>WK</string>
        </property>
       </widget>
      </item>
     </layout>
    </item>

    <!-- TEAM NAME -->
    <item row="4" column="1">
     <widget class="QLabel" name="labelTeamName">
      <property name="text">
       <string>Team Name</string>
      </property>
     </widget>
    </item>

    <!-- SAVE BUTTON -->
    <item row="5" column="1">
     <widget class="QPushButton" name="btnSave">
      <property name="text">
       <string>Save Team</string>
      </property>
     </widget>
    </item>

    <!-- SCORE BUTTON -->
    <item row="6" column="1">
     <widget class="QPushButton" name="btnScore">
      <property name="text">
       <string>Calculate Score</string>
      </property>
     </widget>
    </item>

   </layout>
  </widget>

  <!-- MENU -->
  <widget class="QMenuBar" name="menubar">
   <widget class="QMenu" name="menuManage">
    <property name="title">
     <string>Manage Teams</string>
    </property>

    <addaction name="actionNew_Team"/>
    <addaction name="actionOpen_Team"/>
    <addaction name="actionSave_Team"/>
    <addaction name="actionEvaluate_Team"/>

   </widget>
   <addaction name="menuManage"/>
  </widget>

  <!-- ACTIONS -->
  <action name="actionNew_Team">
   <property name="text">
    <string>New Team</string>
   </property>
  </action>

  <action name="actionOpen_Team">
   <property name="text">
    <string>Open Team</string>
   </property>
  </action>

  <action name="actionSave_Team">
   <property name="text">
    <string>Save Team</string>
   </property>
  </action>

  <action name="actionEvaluate_Team">
   <property name="text">
    <string>Evaluate Team</string>
   </property>
  </action>

 </widget>
